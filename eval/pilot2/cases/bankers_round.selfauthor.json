{
  "impl": "import math\n\n\ndef bankers_round(x):\n    \"\"\"Round x to the nearest integer, rounding ties (exactly .5) to the\n    nearest even integer (banker's rounding).\n\n    Examples:\n        2.5 -> 2, 3.5 -> 4, 0.5 -> 0, -0.5 -> 0\n    \"\"\"\n    f = math.floor(x)\n    diff = x - f\n    if diff < 0.5:\n        return int(f)\n    elif diff > 0.5:\n        return int(f + 1)\n    else:\n        # exactly halfway: round to the even neighbor\n        if f % 2 == 0:\n            return int(f)\n        else:\n            return int(f + 1)\n",
  "tests": [
    {"input": 2.5, "expected": 2},
    {"input": 3.5, "expected": 4},
    {"input": 0.5, "expected": 0},
    {"input": -0.5, "expected": 0},
    {"input": 1.5, "expected": 2},
    {"input": -1.5, "expected": -2},
    {"input": -2.5, "expected": -2},
    {"input": -3.5, "expected": -4},
    {"input": 4.5, "expected": 4},
    {"input": 5.5, "expected": 6},
    {"input": 100.5, "expected": 100},
    {"input": 101.5, "expected": 102},
    {"input": 2.4, "expected": 2},
    {"input": 2.6, "expected": 3},
    {"input": -2.4, "expected": -2},
    {"input": -2.6, "expected": -3},
    {"input": 2.49999, "expected": 2},
    {"input": 2.50001, "expected": 3},
    {"input": -2.49999, "expected": -2},
    {"input": -2.50001, "expected": -3},
    {"input": 0.0, "expected": 0},
    {"input": 1.0, "expected": 1},
    {"input": -1.0, "expected": -1},
    {"input": 2, "expected": 2},
    {"input": 3, "expected": 3},
    {"input": -7, "expected": -7},
    {"input": 0, "expected": 0},
    {"input": 0.49, "expected": 0},
    {"input": 0.51, "expected": 1},
    {"input": -0.49, "expected": 0},
    {"input": -0.51, "expected": -1},
    {"input": 6.5, "expected": 6},
    {"input": 7.5, "expected": 8},
    {"input": 1000000.5, "expected": 1000000},
    {"input": 1000001.5, "expected": 1000002}
  ]
}
