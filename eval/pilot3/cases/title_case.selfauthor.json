{"impl": "def title_case(s):\n    \"\"\"Convert string to title case: uppercase first char, lowercase rest per word, preserve apostrophes.\"\"\"\n    words = s.split()\n    result = []\n    for word in words:\n        if word:\n            # Uppercase first character, lowercase the rest\n            titled = word[0].upper() + word[1:].lower()\n            result.append(titled)\n    return ' '.join(result)", "tests": [{"input": "hello world", "expected": "Hello World"}, {"input": "don't", "expected": "Don't"}, {"input": "the quick brown fox", "expected": "The Quick Brown Fox"}, {"input": "i am learning python", "expected": "I Am Learning Python"}, {"input": "HELLO WORLD", "expected": "Hello World"}, {"input": "hELLo WoRLd", "expected": "Hello World"}, {"input": "a b c", "expected": "A B C"}, {"input": "single", "expected": "Single"}, {"input": "it's a test", "expected": "It's A Test"}, {"input": "don't worry it'll be fine", "expected": "Don't Worry It'll Be Fine"}, {"input": "   multiple   spaces   ", "expected": "Multiple Spaces"}, {"input": "123 abc 456", "expected": "123 Abc 456"}, {"input": "mr. smith goes to washington", "expected": "Mr. Smith Goes To Washington"}, {"input": "e-mail address", "expected": "E-mail Address"}, {"input": "one", "expected": "One"}, {"input": "", "expected": ""}, {"input": "a", "expected": "A"}, {"input": "123", "expected": "123"}]}
