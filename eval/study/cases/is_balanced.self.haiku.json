{
  "impl": "def is_balanced(s: str) -> bool:\n    \"\"\"\n    Return True iff the brackets in s are balanced and properly nested.\n    Three types of brackets: () [] {}\n    Other characters are ignored.\n    \"\"\"\n    stack = []\n    matching = {'(': ')', '[': ']', '{': '}'}\n    \n    for char in s:\n        if char in matching:  # Opening bracket\n            stack.append(char)\n        elif char in matching.values():  # Closing bracket\n            if not stack or matching[stack.pop()] != char:\n                return False\n    \n    return len(stack) == 0",
  "tests": [
    {"input": "([])", "expected": true},
    {"input": "([)]", "expected": false},
    {"input": "((", "expected": false},
    {"input": "", "expected": true},
    {"input": "()", "expected": true},
    {"input": "[]", "expected": true},
    {"input": "{}", "expected": true},
    {"input": "()()", "expected": true},
    {"input": "([{}])", "expected": true},
    {"input": "{[()]}", "expected": true},
    {"input": ")", "expected": false},
    {"input": "]", "expected": false},
    {"input": "}", "expected": false},
    {"input": "([)]", "expected": false},
    {"input": "{[}]", "expected": false},
    {"input": "((()))", "expected": true},
    {"input": "[[]]", "expected": true},
    {"input": "{{}}", "expected": true},
    {"input": "({[]})", "expected": true},
    {"input": "(a[b{c}d]e)", "expected": true},
    {"input": "text (with brackets) and {other} stuff [here]", "expected": true},
    {"input": "no brackets here", "expected": true},
    {"input": "( ] )", "expected": false},
    {"input": "( [ } ]", "expected": false},
    {"input": "{ [ ( ) ] }", "expected": true},
    {"input": "((()))(())", "expected": true},
    {"input": "([{}()])", "expected": true},
    {"input": "({[]}{})", "expected": true},
    {"input": "([)])", "expected": false},
    {"input": "(()", "expected": false},
    {"input": "())", "expected": false},
    {"input": ")(", "expected": false},
    {"input": "[{]}", "expected": false},
    {"input": "({[}])", "expected": false},
    {"input": "(", "expected": false},
    {"input": "[", "expected": false},
    {"input": "{", "expected": false},
    {"input": "   ", "expected": true},
    {"input": "a", "expected": true},
    {"input": "abc", "expected": true},
    {"input": "()", "expected": true},
    {"input": "( )", "expected": true},
    {"input": "( \n )", "expected": true}
  ]
}
