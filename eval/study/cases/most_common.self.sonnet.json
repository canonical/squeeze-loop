{
  "impl": "def most_common(xs):\n    if not xs:\n        return None\n    counts = {}\n    for x in xs:\n        counts[x] = counts.get(x, 0) + 1\n    max_count = max(counts.values())\n    candidates = [k for k, v in counts.items() if v == max_count]\n    return min(candidates)\n",
  "tests": [
    {"input": [], "expected": null},
    {"input": [1], "expected": 1},
    {"input": [1, 2, 2, 3, 3], "expected": 2},
    {"input": [3, 3, 2, 2], "expected": 2},
    {"input": [1, 1, 1], "expected": 1},
    {"input": [5, 5, 3, 3, 1, 1], "expected": 1},
    {"input": [4, 4, 4, 2, 2], "expected": 4},
    {"input": [7, 3, 7, 3, 7], "expected": 7},
    {"input": [10, 20, 10, 20, 30], "expected": 10},
    {"input": [-1, -1, 2, 2], "expected": -1},
    {"input": [0, 0, 1, 1, -1, -1], "expected": -1},
    {"input": [42], "expected": 42},
    {"input": [1, 2, 3], "expected": 1},
    {"input": [2, 2, 1, 3, 3], "expected": 2}
  ]
}
