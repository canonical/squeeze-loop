{
  "impl": "def merge_intervals(intervals):\n    if not intervals:\n        return []\n    sorted_intervals = sorted(intervals, key=lambda x: x[0])\n    merged = [sorted_intervals[0]]\n    for start, end in sorted_intervals[1:]:\n        last = merged[-1]\n        if start <= last[1]:\n            if end > last[1]:\n                last[1] = end\n        else:\n            merged.append([start, end])\n    return merged\n",
  "tests": [
    {"input": [], "expected": []},
    {"input": [[1, 3]], "expected": [[1, 3]]},
    {"input": [[1, 3], [2, 6], [8, 10], [15, 18]], "expected": [[1, 6], [8, 10], [15, 18]]},
    {"input": [[1, 4], [4, 5]], "expected": [[1, 5]]},
    {"input": [[1, 2], [2, 3]], "expected": [[1, 3]]},
    {"input": [[1, 5], [2, 3]], "expected": [[1, 5]]},
    {"input": [[3, 6], [1, 4]], "expected": [[1, 6]]},
    {"input": [[1, 2], [3, 4], [5, 6]], "expected": [[1, 2], [3, 4], [5, 6]]},
    {"input": [[1, 10], [2, 3], [4, 5], [6, 7]], "expected": [[1, 10]]},
    {"input": [[5, 10], [1, 3], [7, 15]], "expected": [[1, 3], [5, 15]]},
    {"input": [[1, 1]], "expected": [[1, 1]]},
    {"input": [[1, 1], [1, 1]], "expected": [[1, 1]]},
    {"input": [[1, 3], [5, 7], [2, 6]], "expected": [[1, 7]]},
    {"input": [[0, 0], [1, 1], [2, 2]], "expected": [[0, 0], [1, 1], [2, 2]]},
    {"input": [[0, 1], [1, 2], [2, 3]], "expected": [[0, 3]]}
  ]
}
