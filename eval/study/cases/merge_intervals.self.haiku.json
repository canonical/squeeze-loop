{
  "impl": "def merge_intervals(intervals):\n    if not intervals:\n        return []\n    \n    sorted_intervals = sorted(intervals, key=lambda x: x[0])\n    \n    merged = [sorted_intervals[0]]\n    \n    for start, end in sorted_intervals[1:]:\n        last_start, last_end = merged[-1]\n        \n        if start <= last_end:\n            merged[-1] = [last_start, max(last_end, end)]\n        else:\n            merged.append([start, end])\n    \n    return merged",
  "tests": [
    {
      "input": [],
      "expected": []
    },
    {
      "input": [[1, 5]],
      "expected": [[1, 5]]
    },
    {
      "input": [[1, 3], [2, 6], [8, 10], [15, 18]],
      "expected": [[1, 6], [8, 10], [15, 18]]
    },
    {
      "input": [[1, 4], [2, 3]],
      "expected": [[1, 4]]
    },
    {
      "input": [[1, 2], [2, 3]],
      "expected": [[1, 3]]
    },
    {
      "input": [[2, 3], [1, 2]],
      "expected": [[1, 3]]
    },
    {
      "input": [[1, 2], [2, 3], [3, 4]],
      "expected": [[1, 4]]
    },
    {
      "input": [[5, 7], [1, 3], [2, 4]],
      "expected": [[1, 4], [5, 7]]
    },
    {
      "input": [[1, 10], [2, 3], [4, 5], [6, 7]],
      "expected": [[1, 10]]
    },
    {
      "input": [[1, 2], [3, 4], [5, 6]],
      "expected": [[1, 2], [3, 4], [5, 6]]
    },
    {
      "input": [[2, 5], [1, 3], [3, 7], [6, 8]],
      "expected": [[1, 8]]
    },
    {
      "input": [[0, 0], [1, 1]],
      "expected": [[0, 0], [1, 1]]
    },
    {
      "input": [[0, 0], [0, 0]],
      "expected": [[0, 0]]
    },
    {
      "input": [[-5, -2], [-3, 0], [1, 3]],
      "expected": [[-5, 0], [1, 3]]
    },
    {
      "input": [[1, 1], [1, 1], [1, 1]],
      "expected": [[1, 1]]
    }
  ]
}
