  "impl": "def dedup_adjacent(xs):\n    \"\"\"Remove only consecutive duplicate elements, keeping non-adjacent repeats.\"\"\"\n    if not xs:\n        return []\n    \n    result = [xs[0]]\n    for i in range(1, len(xs)):\n        if xs[i] != xs[i-1]:\n            result.append(xs[i])\n    \n    return result",
