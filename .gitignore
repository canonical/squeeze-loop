# LaTeX build intermediates (regenerated by pdflatex/bibtex)
tex/*.aux
tex/*.log
tex/*.out
tex/*.bbl
tex/*.blg
tex/*.toc

# Regenerable ground-truth warehouse (rebuild deterministically with
# src/A/ground-truth/build_ground_truth.py; its content is pinned by the
# committed history_ledger.sig).
src/A/ground-truth/shared/*.db
src/B/ground-truth/shared/*.db
src/C/ground-truth/shared/*.db

# Third-party source PDFs: re-downloadable from the arXiv IDs in bib/records/*.md;
# integrity is pinned by bib/archive/SHA256SUMS (which IS committed).
# Excluded to keep copyrighted binaries out of git history and avoid ~82MB of bloat.
bib/archive/*.pdf

# Python bytecode
__pycache__/
*.pyc

# Coq/Rocq compiled artifacts (regenerated by `coqc` / `rocq compile`;
# sources are the committed *.v files). src/D ground truth recompiles them.
*.vo
*.vos
*.vok
*.glob
.*.aux
.lia.cache
.nia.cache

# LXC slirp4netns runtime state (per-container, host-local)
*.slirp.pid

# Agent tooling (skills live in config/skills; .claude/skills is just a symlink to it)
.claude/

# latexmk database / file list (regenerated)
tex/*.fdb_latexmk
tex/*.fls

# Stray live-probe answer dumps (transcripts of record are the *.jsonl reports)
verify/reports/live/answers_*.json

# real-use-case: keep the squeeze harness (docs, scripts, found-bug write-ups) but NOT
# the vendored external lace source (GPL-3, re-clonable), build artifacts, or working
# Creusot run-trees.
real-use-case/lace/
real-use-case/build/
real-use-case/cwork/
real-use-case/config/
real-use-case/sl_syntax_07/
real-use-case/sl_inc_max_3/
real-use-case/reopen_trustedstatic/
real-use-case/reopen_weakopacity_src/
